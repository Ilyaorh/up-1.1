<Window x:Class="InventoryControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учёт и контроль инвентаризации" 
        Height="700" 
        Width="1200"
        WindowState="Maximized"
        Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <GroupBox Grid.Row="0" Header="Поиск" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Поиск по:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1" x:Name="cmbSearchField" Margin="0,0,10,0">
                    <ComboBoxItem Content="ФИО" IsSelected="True"/>
                    <ComboBoxItem Content="Инвентарный номер"/>
                    <ComboBoxItem Content="Тип оборудования"/>
                    <ComboBoxItem Content="Место расположения"/>
                </ComboBox>

                <TextBlock Grid.Column="2" Text="Строка поиска:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Column="3" x:Name="txtSearch" Margin="0,0,10,0" 
                         TextChanged="txtSearch_TextChanged"/>

                <Button Grid.Column="4" Content="Найти" Width="80" Margin="0,0,10,0" 
                        Click="btnSearch_Click"/>
                <Button Grid.Column="5" Content="Сбросить" Width="80" HorizontalAlignment="Left"
                        Click="btnResetSearch_Click"/>
            </Grid>
        </GroupBox>


        <GroupBox Grid.Row="1" Header="Управление" Margin="0,0,0,10" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить" Width="120" Height="30" Margin="0,0,10,0"
                        Click="btnAdd_Click" Background="#4CAF50" Foreground="White"/>
                <Button Content="✏️ Изменить" Width="120" Height="30" Margin="0,0,10,0"
                        Click="btnEdit_Click" Background="#2196F3" Foreground="White"/>
                <Button Content="🗑️ Удалить" Width="120" Height="30" Margin="0,0,10,0"
                        Click="btnDelete_Click" Background="#f44336" Foreground="White"/>
                <Button Content="🔄 Обновить" Width="120" Height="30" Margin="0,0,10,0"
                        Click="btnRefresh_Click" Background="#FF9800" Foreground="White"/>
            </StackPanel>
        </GroupBox>


        <GroupBox Grid.Row="2" Header="Данные инвентаризации" Margin="0,0,0,10" Padding="10">
            <DataGrid x:Name="dgInventory" 
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F2F2F2"
                      RowHeight="35"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>
                    <DataGridTextColumn Header="Инвентарный номер" Binding="{Binding InventoryNumber}" Width="120"/>
                    <DataGridTextColumn Header="Тип оборудования" Binding="{Binding EquipmentType}" Width="150"/>
                    <DataGridTextColumn Header="Стоимость" Binding="{Binding EquipmentCost, StringFormat={}{0:N2} ₽}" Width="120" />
                    <DataGridTextColumn Header="Место расположения" Binding="{Binding Location}" Width="*"/>
                    <DataGridTextColumn Header="Дата добавления" Binding="{Binding CreatedDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>


        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Готов"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="txtRecordCount" Text="Записей: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>