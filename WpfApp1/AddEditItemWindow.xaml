<Window x:Class="InventoryControl.AddEditItemWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление/Редактирование записи" 
        Height="400" 
        Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="ФИО:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtFullName" Height="25"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Инвентарный номер:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtInventoryNumber" Height="25"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Тип оборудования:" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="cmbEquipmentType" Height="25" IsEditable="True">
                <ComboBoxItem Content="Компьютер"/>
                <ComboBoxItem Content="Ноутбук"/>
                <ComboBoxItem Content="Монитор"/>
                <ComboBoxItem Content="Принтер"/>
                <ComboBoxItem Content="Ксерокс"/>
                <ComboBoxItem Content="Сканер"/>
                <ComboBoxItem Content="Сервер"/>
                <ComboBoxItem Content="Сетевое оборудование"/>
                <ComboBoxItem Content="Клавиатура"/>
                <ComboBoxItem Content="Мышь"/>
                <ComboBoxItem Content="Колонки"/>
                <ComboBoxItem Content="Телефон"/>
                <ComboBoxItem Content="Планшет"/>
                <ComboBoxItem Content="Проектор"/>
                <ComboBoxItem Content="Веб-камера"/>
            </ComboBox>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Стоимость (₽):" VerticalAlignment="Center"/>
            <TextBox Grid.Row="6" Grid.Column="1" x:Name="txtCost" Height="25" 
                     PreviewTextInput="txtCost_PreviewTextInput"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Место расположения:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="8" Grid.Column="1" x:Name="txtLocation" Height="25"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Width="100" Height="30" Margin="0,0,10,0"
                    Click="btnSave_Click" Background="#4CAF50" Foreground="White"/>
            <Button Content="Отмена" Width="100" Height="30"
                    Click="btnCancel_Click" Background="#f44336" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>